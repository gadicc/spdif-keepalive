#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/spdif-keepalive-check.XXXXXX")"
trap 'rm -rf "$tmpdir"' EXIT

copy_worktree() {
  cd "$repo_root"
  git ls-files -co --exclude-standard -z |
    while IFS= read -r -d '' path; do
      [[ -e "$path" ]] && printf '%s\0' "$path"
    done |
    tar --null -T - -cf - |
    tar -xf - -C "$tmpdir"
}

copy_worktree
cd "$tmpdir"
git init -q
git add -A

PYTHONDONTWRITEBYTECODE=1 PYTHONPATH=src pytest -q -p no:cacheprovider
python -m compileall -q src
build_log="$tmpdir/python-build.log"
if ! python -m build --wheel --no-isolation --outdir "$tmpdir/dist" >"$build_log" 2>&1; then
  cat "$build_log" >&2
  exit 1
fi
bash -n systemd/spdif-keepalive-sleep
namcap packaging/arch/PKGBUILD

(
  cd packaging/arch
  makepkg --printsrcinfo >/dev/null
)

echo "checks passed"
